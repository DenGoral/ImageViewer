<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="AccentColorNative">#264982</Color>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="SurfaceMain">#0A0E14</SolidColorBrush>
            <SolidColorBrush x:Key="SurfaceCard">#252733</SolidColorBrush>
            <SolidColorBrush x:Key="TextPrimary">White</SolidColorBrush>
            <SolidColorBrush x:Key="TextSecondary">LightSlateGray</SolidColorBrush>
            <SolidColorBrush x:Key="SurfaceSecondary">#0D111D</SolidColorBrush>
            <SolidColorBrush x:Key="AccentColor" Color="{StaticResource AccentColorNative}"/>
        </ResourceDictionary>
        
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="SurfaceMain">#F4F4F4</SolidColorBrush>
            <SolidColorBrush x:Key="SurfaceCard">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="TextPrimary">#1A1A1A</SolidColorBrush>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>